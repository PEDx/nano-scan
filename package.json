{
  "name": "nano-scan",
  "version": "0.0.5",
  "description": "A browser scanning component based on zxing-wasm",
  "main": "dist/umd/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:types",
    "build:js": "rolldown -c rolldown.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "cd docs && vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "homepage": "https://github.com/PEDx/nano-scan",
  "repository": {
    "type": "git",
    "url": "https://github.com/PEDx/nano-scan"
  },
  "keywords": [
    "scan",
    "qrcode",
    "barcode",
    "zxing",
    "scanner"
  ],
  "author": "alan.ped",
  "license": "MIT",
  "dependencies": {
    "zxing-wasm": "^2.1.2"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "jsdom": "^29.0.2",
    "rolldown": "^1.0.0-beta.8",
    "tslib": "^2.8.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
